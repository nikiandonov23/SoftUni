@{
    ViewData["Title"] = "CarGarage – Твоят гараж онлайн";
}

<div class="container my-5">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-primary mb-0">Добре дошъл в CarGarage</h1>
        </div>

        <div class="d-flex gap-2">
           
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg shadow-sm">
                <i class="bi bi-house-door me-2"></i>Начало
            </a>

            
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="MyCars" asp-action="Index" class="btn btn-primary btn-lg shadow-sm">
                    <i class="bi bi-car-front-fill me-2"></i>Моите автомобили
                </a>
            }
        </div>
    </div>

    
    <div class="row mb-5">
        <div class="col-12">
            <p class="lead text-muted">
                Управлявай автомобилите си, следи ремонти, фактури и сервизи на едно място.
            </p>
        </div>
    </div>

    <div class="row g-4">

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 transition-card">
                <div class="card-body text-center py-4">
                    <i class="bi bi-car-front-fill display-1 text-success mb-3"></i>
                    <h5 class="card-title fw-bold">Моите автомобили</h5>
                    <p class="card-text text-muted">
                        Добавяй и управлявай своите автомобили.
                    </p>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="MyCars" asp-action="Index" class="btn btn-outline-success stretched-link">
                            Към моите автомобили
                        </a>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-success stretched-link">
                            Влез, за да добавиш
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 transition-card">
                <div class="card-body text-center py-4">
                    <i class="bi bi-search display-1 text-primary mb-3"></i>
                    <h5 class="card-title fw-bold">Търси автомобил</h5>
                    <p class="card-text text-muted">
                        Намери кола по марка, модел, година или VIN.
                    </p>
                    <a asp-controller="Search" asp-action="Index" class="btn btn-outline-primary stretched-link">
                        Започни търсене
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 transition-card">
                <div class="card-body text-center py-4">
                    <i class="bi bi-receipt display-1 text-warning mb-3"></i>
                    <h5 class="card-title fw-bold">Фактури & разходи</h5>
                    <p class="card-text text-muted">
                        Следи всички ремонти и плащания на едно място.
                    </p>
                    <a asp-controller="Invoices" asp-action="Index" class="btn btn-outline-warning stretched-link">
                        Моите фактури
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 transition-card">
                <div class="card-body text-center py-4">
                    <i class="bi bi-people display-1 text-secondary mb-3"></i>
                    <h5 class="card-title fw-bold">Клиенти / Фирми</h5>
                    <p class="card-text text-muted">
                        Управлявай клиенти и история на ремонти.
                    </p>
                    <a asp-controller="Clients" asp-action="Index" class="btn btn-outline-secondary stretched-link">
                        Преглед на клиенти
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 transition-card">
                <div class="card-body text-center py-4">
                    <i class="bi bi-shop-window display-1 text-danger mb-3"></i>
                    <h5 class="card-title fw-bold">Marketplace</h5>
                    <p class="card-text text-muted">
                        Търси части втора ръка от реални сервизи.
                    </p>
                    <a asp-controller="Marketplace" asp-action="Index" class="btn btn-outline-danger stretched-link">
                        Прегледай обяви
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 transition-card">
                <div class="card-body text-center py-4">
                    <i class="bi bi-chat-dots display-1 text-dark mb-3"></i>
                    <h5 class="card-title fw-bold">Коментари & части</h5>
                    <p class="card-text text-muted">
                        Чети ревюта и споделяй опит с другите.
                    </p>
                    <a asp-controller="Comments" asp-action="Index" class="btn btn-outline-dark stretched-link">
                        Към коментарите
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mt-5">
        <div class="col-lg-12 text-center">
            <hr class="my-5 opacity-25" />
            <h3 class="mb-4 fw-bold">Защо да избереш CarGarage?</h3>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="p-4 bg-light rounded-3 shadow-sm border">
                        <i class="bi bi-car-front-fill fs-1 text-primary mb-3 d-block"></i>
                        <h5 class="fw-bold">Лесно управление</h5>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4 bg-light rounded-3 shadow-sm border">
                        <i class="bi bi-tools fs-1 text-success mb-3 d-block"></i>
                        <h5 class="fw-bold">Проследяване</h5>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4 bg-light rounded-3 shadow-sm border">
                        <i class="bi bi-currency-euro fs-1 text-warning mb-3 d-block"></i>
                        <h5 class="fw-bold">Контрол</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    
    .transition-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border-radius: 15px; 
    }

        .transition-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }
</style>