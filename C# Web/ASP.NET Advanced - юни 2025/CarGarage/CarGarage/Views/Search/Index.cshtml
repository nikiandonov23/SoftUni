@model CarGarage.ViewModels.Search.SearchCarsViewModel

@{
    ViewData["Title"] = "Търсене на автомобили";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold text-primary"><i class="bi bi-search me-2"></i>Търсачка</h1>
        <span class="badge bg-secondary px-3 py-2">Намерени резултати: @Model.Results.Count()</span>
    </div>

    
    <div class="card shadow-sm border-0 mb-5 bg-white rounded-4">
        <div class="card-body p-4">
            <form method="get" asp-controller="Search" asp-action="Index" class="row g-3">

                <div class="col-md-4">
                    <label class="form-label fw-bold small text-uppercase text-muted">Рег. номер / VIN</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control bg-light border-0 shadow-none" placeholder="Въведи номер за търсене...">
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase text-muted">Марка</label>
                    <select asp-for="MakeId" class="form-select bg-light border-0 shadow-none" id="makeSelect"
                            asp-items="@(new SelectList(Model.Makes, "Id", "Name"))">
                        <option value="">-- Всички марки --</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold small text-uppercase text-muted">Модел</label>
                    <select asp-for="ModelId" class="form-select bg-light border-0 shadow-none" id="modelSelect"
                            asp-items="@(new SelectList(Model.Models, "Id", "Name"))">
                        <option value="">-- Всички модели --</option>
                    </select>
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100 shadow-sm py-2 fw-bold">
                        Филтрирай
                    </button>
                </div>
            </form>
        </div>
    </div>

    
    @if (!Model.Results.Any())
    {
        <div class="text-center py-5 bg-light rounded-4 border border-dashed">
            <i class="bi bi-car-front display-1 text-muted opacity-25"></i>
            <h3 class="mt-3 fw-light">Няма намерени автомобили</h3>
            <p class="text-muted">Пробвай да промениш критериите за търсене.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var car in Model.Results)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden card-hover">
                        @if (!string.IsNullOrEmpty(car.ImageUrl))
                        {
                            <img src="@car.ImageUrl" class="card-img-top" style="height: 200px; object-fit: cover;" alt="Car Image">
                        }
                        else
                        {
                            <div class="bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-image text-muted display-4"></i>
                            </div>
                        }

                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="fw-bold mb-0">@car.Make @car.Model</h5>
                                <span class="badge bg-primary rounded-pill">@car.ModelYear</span>
                            </div>

                            <div class="small text-muted mb-3">
                                <div class="mb-1"><i class="bi bi-hash me-2"></i><strong>Рег. номер:</strong> @(car.RegistrationNumber ?? "N/A")</div>
                                <div><i class="bi bi-speedometer2 me-2"></i><strong>Пробег:</strong> @(car.Mileage?.ToString("N0") ?? "0") км</div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(car.Notes))
                            {
                                <p class="card-text small text-truncate bg-light p-2 rounded">
                                    <i class="bi bi-info-circle me-1"></i> @car.Notes
                                </p>
                            }
                        </div>

                        <div class="card-footer bg-white border-0 pb-3">
                            <a asp-controller="MyCars" asp-action="Edit" asp-route-id="@car.Id" class="btn btn-outline-primary w-100 rounded-pill btn-sm fw-bold">
                                Преглед и детайли
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            
            $('#makeSelect').on('change', function () {
                var makeId = $(this).val();
                var $modelSelect = $('#modelSelect');

                
                $modelSelect.empty().append('<option value="">-- Всички модели --</option>');

                if (makeId) {
                    
                    $.getJSON('/MyCars/GetModelsByMake?makeId=' + makeId, function (data) {
                        $.each(data, function (index, item) {
                            $modelSelect.append($('<option>', {
                                value: item.id,
                                text: item.name
                            }));
                        });
                    });
                }
            });
        });
    </script>
}

<style>
    .card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    //asfd
        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .border-dashed {
        border-style: dashed !important;
    }
</style>