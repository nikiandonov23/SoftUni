@model IEnumerable<CarGarage.ViewModels.Parts.PartViewModel>

@{
    ViewData["Title"] = "История на обслужването";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">История на обслужването</h2>
        <div>
            <a asp-controller="MyCars" asp-action="Index" class="btn btn-outline-secondary me-2">
                <i class="bi bi-arrow-left-circle me-1"></i>Моите Автомобили
            </a>

            <a asp-action="Create" asp-route-carId="@ViewBag.CarId" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle me-1"></i>Добави част
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Категория</th>
                        <th>Описание</th>
                        <th>Количество</th>
                        <th>Ед. цена</th>
                        <th>Общо</th>
                        <th class="text-center">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center p-5 text-muted">
                                Няма намерени записи за този автомобил.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 text-uppercase small fw-bold text-muted">@item.CategoryName</td>
                                <td>@item.Description</td>
                                <td>@item.Quantity бр.</td>
                                <td>@item.UnitPrice.ToString("N2") лв.</td>
                                <td class="fw-bold text-dark">@item.TotalPrice.ToString("N2") лв.</td>
                                <td class="text-center">
                                    <div class="btn-group shadow-sm">
                                        @if (item.InvoiceId != null)
                                        {
                                            
                                            <a asp-controller="Invoices" asp-action="Details" asp-route-id="@item.InvoiceId" target="_blank" class="btn btn-sm btn-outline-info">
                                                <i class="bi bi-file-earmark-pdf"></i> Фактура
                                            </a>
                                        }
                                        else
                                        {
                                           
                                            <button class="btn btn-sm btn-outline-secondary disabled" title="Частта още не е добавена във фактура">
                                                <i class="bi bi-hourglass"></i> Нефактурирано
                                            </button>
                                        }

                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> Изтрий
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>