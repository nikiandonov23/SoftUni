@model IEnumerable<CarGarage.ViewModels.Invoices.InvoiceFullViewModel>

@{
    ViewData["Title"] = "Архив на фактури";
}

<div class="container mt-5">
    @* Заглавна секция с бутон *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark"><i class="bi bi-receipt-cutoff me-2 text-primary"></i>Архив на фактури</h2>
            <p class="text-muted mb-0">Преглед и управление на всички издадени документи</p>
        </div>
        
        @* Бутонът, който води към гаража за избор на кола *@
        <a asp-controller="MyCars" asp-action="Index" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Нова фактура
        </a>
    </div>

    @* Информационно съобщение (по желание, за яснота на потребителя) *@
    <div class="alert alert-info d-flex align-items-center shadow-sm border-0 mb-4" role="alert">
        <i class="bi bi-info-circle-fill fs-4 me-3"></i>
        <div>
            За да издадете нова фактура, изберете бутона <strong>"Генерирай фактура"</strong> срещу съответния автомобил в гаража си.
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Номер</th>
                            <th>Дата</th>
                            <th>Автомобил</th>
                            <th class="text-end">Сума с ДДС</th>
                            <th class="text-center">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var invoice in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold text-primary">@invoice.InvoiceNumber</span>
                                    </td>
                                    <td>@invoice.IssuedDate.ToString("dd.MM.yyyy")</td>
                                    <td>@invoice.CarInfo</td>
                                    <td class="text-end fw-bold text-success">
                                        @invoice.GrandTotal.ToString("N2") лв.
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@invoice.InvoiceNumber" class="btn btn-sm btn-outline-info shadow-sm me-1">
                                            <i class="bi bi-eye"></i> Преглед
                                        </a>
                                        <button onclick="window.print()" class="btn btn-sm btn-outline-secondary shadow-sm">
                                            <i class="bi bi-printer"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-file-earmark-x d-block display-4 mb-3"></i>
                                    Все още нямате издадени фактури.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>