@model CarGarage.ViewModels.Cars.CreateCarViewModel

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div class="row g-4">
        <div class="col-md-6">
            <label asp-for="RegistrationNumber" class="form-label fw-bold"></label>
            <input asp-for="RegistrationNumber" class="form-control" />
            <span asp-validation-for="RegistrationNumber" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Vin" class="form-label fw-bold"></label>
            <input asp-for="Vin" class="form-control" />
            <span asp-validation-for="Vin" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="MakeId" class="form-label fw-bold">Марка *</label>
            <select asp-for="MakeId" id="MakeSelect" class="form-select"
                    asp-items="@(new SelectList(Model.MakeList, "Id", "Name"))">
                <option value="">-- Избери марка --</option>
            </select>
            <span asp-validation-for="MakeId" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="ModelId" class="form-label fw-bold">Модел *</label>
            <select asp-for="ModelId" id="ModelSelect" class="form-select">
                <option value="">-- Избери модел --</option>
            </select>
            <span asp-validation-for="ModelId" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="ModelYear" class="form-label fw-bold"></label>
            <input asp-for="ModelYear" class="form-control" />
            <span asp-validation-for="ModelYear" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Mileage" class="form-label fw-bold"></label>
            <input asp-for="Mileage" class="form-control" />
        </div>

        <div class="col-md-6">
            <label asp-for="ImageUrl" class="form-label fw-bold"></label>
            <input asp-for="ImageUrl" class="form-control" />
        </div>

        <div class="col-12">
            <label asp-for="Notes" class="form-label fw-bold"></label>
            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        </div>
    </div>

    <button type="submit" class="btn btn-success mt-4">Запази колата</button>
</form>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(function () {
            $('#MakeSelect').change(function () {
                var selectedMakeId = $(this).val();
                var $modelSelect = $('#ModelSelect');

                // 1. Чистим дропдауна за модели
                $modelSelect.empty().append('<option value="">-- Избери модел --</option>');

                if (selectedMakeId) {
                    // 2. AJAX заявка
                    $.getJSON('@Url.Action("GetModelsByMake", "MyCars")', { makeId: selectedMakeId }, function (data) {
                        console.log("Данни от сървъра:", data); // Виж това в F12 Console

                        $.each(data, function (i, item) {
                            // ВАЖНО: Тук ползваме малки букви 'id' и 'name'
                            $modelSelect.append($('<option>', {
                                value: item.id,
                                text: item.name
                            }));
                        });
                    }).fail(function() {
                        alert("Грешка при зареждане на моделите!");
                    });
                }
            });
        });
    </script>
}