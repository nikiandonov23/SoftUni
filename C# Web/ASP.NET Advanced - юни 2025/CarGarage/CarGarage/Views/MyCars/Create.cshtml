@model CarGarage.ViewModels.MyCars.CreateCarViewModel
@{
    ViewData["Title"] = "Добави нов автомобил – CarGarage";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <h1 class="display-5 fw-bold text-primary text-center mb-4">
                Добави нов автомобил
            </h1>
            <p class="text-center text-muted mb-5">
                Попълни данните за автомобила
            </p>

            <form asp-action="Create" method="post" id="createCarForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger mb-4"></div>

                <div class="row g-4">

                    <!-- 1. Регистрационен номер -->
                    <div class="col-12">
                        <label asp-for="RegistrationNumber" class="form-label fw-bold">
                            Регистрационен номер <span class="text-danger">*</span>
                        </label>
                        <input asp-for="RegistrationNumber" class="form-control form-control-lg" />
                        <span asp-validation-for="RegistrationNumber" class="text-danger"></span>
                    </div>

                    <!-- 2. Марка -->
                    <div class="col-md-4">
                        <label asp-for="Make" class="form-label fw-bold">Марка <span class="text-danger">*</span></label>
                        <select asp-for="Make" class="form-select form-select-lg" id="Make">
                            <option value="">-- Избери марка --</option>
                        </select>
                        <span asp-validation-for="Make" class="text-danger"></span>
                    </div>

                    <!-- 3. Модел -->
                    <div class="col-md-4">
                        <label asp-for="Model" class="form-label fw-bold">Модел <span class="text-danger">*</span></label>
                        <select asp-for="Model" class="form-select form-select-lg" id="Model">
                            <option value="">-- Избери модел --</option>
                        </select>
                        <span asp-validation-for="Model" class="text-danger"></span>
                    </div>

                    <!-- 4. Година -->
                    <div class="col-md-4">
                        <label asp-for="ModelYear" class="form-label fw-bold">Година <span class="text-danger">*</span></label>
                        <input asp-for="ModelYear" type="number" class="form-control form-control-lg" id="ModelYear"
                               min="1900" max="2100" placeholder="2023" />
                        <span asp-validation-for="ModelYear" class="text-danger"></span>
                    </div>

                    <!-- 5. Пробег -->
                    <div class="col-md-6">
                        <label asp-for="Mileage" class="form-label fw-bold">Пробег (км)</label>
                        <input asp-for="Mileage" type="number" class="form-control form-control-lg" />
                    </div>

                    <!-- 6. URL на снимка -->
                    <div class="col-md-6">
                        <label asp-for="ImageUrl" class="form-label fw-bold">URL на снимка</label>
                        <input asp-for="ImageUrl" class="form-control form-control-lg" placeholder="https://example.com/car.jpg" />
                    </div>

                    <!-- 7. VIN номер (номер на рамата) - предпоследен -->
                    <div class="col-12">
                        <label asp-for="Vin" class="form-label fw-bold">VIN номер (номер на рамата)</label>
                        <input asp-for="Vin" class="form-control form-control-lg" id="vinInput"
                               placeholder="WDD2050402R048000" maxlength="17" />
                        <span asp-validation-for="Vin" class="text-danger"></span>
                        <small class="text-muted">Не е задължителен. Може да оставиш празно или да въведеш за автоматично попълване.</small>
                    </div>

                    <!-- 8. Бележки - последен -->
                    <div class="col-12">
                        <label asp-for="Notes" class="form-label fw-bold">Допълнителни бележки</label>
                        <textarea asp-for="Notes" class="form-control" rows="4"
                                  placeholder="Особености, история, забележки..."></textarea>
                    </div>

                </div>

                <div class="d-grid gap-2 mt-5">
                    <button type="submit" class="btn btn-success btn-lg py-3">
                        <i class="bi bi-plus-circle me-2"></i>
                        Добави автомобил
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {

            // Зареждане на марки
            $.getJSON('https://vpic.nhtsa.dot.gov/api/vehicles/getallmakes?format=json', function (data) {
                $.each(data.Results, function (_, make) {
                    $('#Make').append(`<option value="${make.Make_Name}">${make.Make_Name}</option>`);
                });
            });

            // Зареждане на модели
            $('#Make').on('change', function () {
                const selectedMake = $(this).val();
                const modelSelect = $('#Model');
                modelSelect.empty().append('<option value="">-- Избери модел --</option>');

                if (!selectedMake) return;

                $.getJSON(`https://vpic.nhtsa.dot.gov/api/vehicles/getmodelsformake/${selectedMake}?format=json`, function (data) {
                    $.each(data.Results, function (_, m) {
                        modelSelect.append(`<option value="${m.Model_Name}">${m.Model_Name}</option>`);
                    });
                });
            });

            // === ПОПЪЛВАНЕ ОТ VIN ===
            $('#vinInput').on('blur', function () {
                let vin = $(this).val().trim().toUpperCase();
                if (vin.length !== 17) return;

                $(this).val(vin);

                $.getJSON(`/MyCars/GetCarByVin?vin=${vin}`, function (data) {
                    if (!data) return;

                    $('#vinInput').val(data.Vin || vin);
                    $('#Make').val(data.Make || '').trigger('change');
                    $('#Model').val(data.Model || '');
                    $('#ModelYear').val(data.ModelYear || '');

                    console.log("✅ Попълнено от VIN:", data);
                }).fail(function () {
                    console.error("Грешка при VIN decode");
                });
            });
        });
    </script>
}