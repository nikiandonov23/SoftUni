@model CarGarage.ViewModels.Cars.IndexMyCarsViewModel

@{
    ViewData["Title"] = "Моите автомобили";
}

<div class="container my-5">
    @* Секция със заглавие и бутони за навигация *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold text-primary mb-0">Моите автомобили</h1>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="MyGarage" asp-action="Index" class="btn btn-outline-secondary btn-lg shadow-sm">
                <i class="bi bi-house-door me-2"></i>Моят Гараж
            </a>

            <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
                <i class="bi bi-plus-circle me-2"></i>Добави автомобил
            </a>
        </div>
    </div>

    @if (Model == null || !Model.Cars.Any())
    {
        <div class="text-center py-5 shadow-sm bg-light rounded border">
            <i class="bi bi-car-front display-1 text-muted"></i>
            <h3 class="mt-3">Все още нямате добавени автомобили.</h3>
            <p class="text-muted">Започнете, като добавите първата си кола.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var car in Model.Cars)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 transition-card">
                        @if (!string.IsNullOrEmpty(car.ImageUrl))
                        {
                            <img src="@car.ImageUrl" class="card-img-top" alt="Car Image" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-light text-center py-5 border-bottom" style="height: 200px;">
                                <i class="bi bi-car-front-fill display-2 text-secondary"></i>
                            </div>
                        }

                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold mb-0">@car.Make @car.Model</h5>
                                <span class="badge bg-primary rounded-pill">@car.ModelYear</span>
                            </div>

                            <hr class="text-muted opacity-25">

                            <p class="card-text mb-1">
                                <i class="bi bi-hash text-primary me-2"></i><strong>Рег. номер:</strong>
                                <span class="text-uppercase text-secondary">@(car.RegistrationNumber ?? "Няма")</span>
                            </p>

                            <p class="card-text mb-1">
                                <i class="bi bi-speedometer2 text-primary me-2"></i><strong>Пробег:</strong>
                                <span class="text-secondary">@(car.Mileage?.ToString("N0") ?? "0") км</span>
                            </p>

                            <p class="card-text mb-2">
                                <i class="bi bi-calendar-event text-primary me-2"></i><strong>Добавена на:</strong>
                                <span class="text-secondary">@car.AddedDate.ToString("dd.MM.yyyy") г.</span>
                            </p>

                            @if (!string.IsNullOrWhiteSpace(car.Notes))
                            {
                                <div class="mt-3 p-3 bg-light rounded-3 border-start border-primary border-4">
                                    <small class="fw-bold text-muted d-block text-uppercase small mb-1">Бележки:</small>
                                    <p class="card-text small text-dark mb-0">@car.Notes</p>
                                </div>
                            }
                        </div>

                        <div class="card-footer bg-transparent border-0 pb-3">
                           
                            <div class="mb-2">
                                <a asp-controller="Parts" asp-action="Index" asp-route-carId="@car.Id" class="btn btn-primary w-100 shadow-sm">
                                    <i class="bi bi-wrench-adjustable me-2"></i>Ремонти и Обслужване
                                </a>
                            </div>

                            
                            <div class="mb-2">
                                <a asp-controller="Invoices" asp-action="Create" asp-route-carId="@car.Id" class="btn btn-warning w-100 shadow-sm fw-bold">
                                    <i class="bi bi-receipt me-2"></i>Генерирай Фактура
                                </a>
                            </div>

                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@car.Id" class="btn btn-outline-secondary flex-grow-1">
                                    <i class="bi bi-pencil me-1"></i> Редакция
                                </a>

                                <a asp-action="Delete" asp-route-id="@car.Id" class="btn btn-outline-danger flex-grow-1">
                                    <i class="bi bi-trash me-1"></i> Изтрий
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .transition-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
</style>

@section Scripts {
    
}