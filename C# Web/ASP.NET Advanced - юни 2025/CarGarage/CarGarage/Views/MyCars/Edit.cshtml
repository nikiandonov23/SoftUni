@model CarGarage.ViewModels.Cars.CreateCarViewModel

@{
    ViewData["Title"] = "Редакция на автомобил";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h3 class="card-title mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>Редактиране на автомобил
                    </h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="RegistrationNumber" class="form-label fw-bold text-secondary"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-hash"></i></span>
                                    <input asp-for="RegistrationNumber" class="form-control" placeholder="напр. CB1234AB" />
                                </div>
                                <span asp-validation-for="RegistrationNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Vin" class="form-label fw-bold text-secondary"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-info-circle"></i></span>
                                    <input asp-for="Vin" class="form-control" placeholder="17-цифрен VIN" />
                                </div>
                                <span asp-validation-for="Vin" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="MakeId" class="form-label fw-bold text-secondary">Марка *</label>
                                <select asp-for="MakeId" id="MakeSelect" class="form-select shadow-none"
                                        asp-items="@(new SelectList(Model.MakeList, "Id", "Name"))">
                                    <option value="">-- Избери марка --</option>
                                </select>
                                <span asp-validation-for="MakeId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="ModelId" class="form-label fw-bold text-secondary">Модел *</label>
                                <select asp-for="ModelId" id="ModelSelect" class="form-select shadow-none"
                                        asp-items="@(new SelectList(Model.ModelList, "Id", "Name"))">
                                    <option value="">-- Избери модел --</option>
                                </select>
                                <span asp-validation-for="ModelId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="ModelYear" class="form-label fw-bold text-secondary"></label>
                                <input asp-for="ModelYear" class="form-control shadow-none" />
                                <span asp-validation-for="ModelYear" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Mileage" class="form-label fw-bold text-secondary"></label>
                                <div class="input-group">
                                    <input asp-for="Mileage" class="form-control shadow-none" />
                                    <span class="input-group-text bg-light">км</span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ImageUrl" class="form-label fw-bold text-secondary"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="bi bi-image"></i></span>
                                    <input asp-for="ImageUrl" class="form-control shadow-none" placeholder="https://..." />
                                </div>
                            </div>

                            <div class="col-12">
                                <label asp-for="Notes" class="form-label fw-bold text-secondary"></label>
                                <textarea asp-for="Notes" class="form-control shadow-none" rows="3" placeholder="Добавете важна информация тук..."></textarea>
                                <span asp-validation-for="Notes" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">
                            <a href="@(ViewData["ReturnUrl"] ?? Url.Action("Index", "MyCars"))" class="btn btn-outline-secondary px-4">
                                <i class="bi bi-arrow-left me-2"></i>Отказ
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">
                                <i class="bi bi-check-circle me-2"></i>Запази промените
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            $('#MakeSelect').change(function () {
                var selectedMakeId = $(this).val();
                var $modelSelect = $('#ModelSelect');
                $modelSelect.empty().append('<option value="">-- Избери модел --</option>');
                if (selectedMakeId) {
                    $.getJSON('@Url.Action("GetModelsByMake", "MyCars")', { makeId: selectedMakeId }, function (data) {
                        $.each(data, function (i, item) {
                            $modelSelect.append($('<option>', { value: item.id, text: item.name }));
                        });
                    });
                }
            });
        });
    </script>
}